modules = ["python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["espeak-ng", "freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "sqlite", "tcl", "tk", "unzip", "zlib"]

[agent]
expertMode = true
integrations = ["python_openai_ai_integrations:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Discord Bot"

[[workflows.workflow]]
name = "Start Discord Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python CodeX.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
SYNC_COMMANDS = "true"

[deployment]
run = ["sh", "-c", "python CodeX.py"]
deploymentTarget = "cloudrun"
